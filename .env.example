# ===================================
# DATABASE CONFIGURATION
# ===================================
NEON_DATABASE_URL=postgresql://username:password@host.region.aws.neon.tech/database?sslmode=require

# ===================================
# OSM TRAIL DATABASE
# ===================================
# Local Docker PostGIS used by osm2pgsql during import (scratch/processing DB).
# Not exposed publicly — only used by import and migration scripts.
OSM_DATABASE_URL_LOCAL=postgresql://packrat:packrat@localhost:5433/osm

# osm2pgsql node cache size in MB (default: 800).
# Increase for continent-scale imports to avoid disk-I/O stalls during way processing.
# Rule of thumb: ~40% of available RAM. For a 16 GB machine use 6000; for 32 GB use 12000.
# OSM_CACHE_MB=6000

# Managed production PostGIS (Supabase, Neon, RDS, etc.).
# Matches OSM_DATABASE_URL in the Worker (injected via Hyperdrive at runtime).
# When set, `bun run import` automatically syncs osm_ways + osm_routes here
# after a successful import. Can also be triggered manually with `bun run sync`.
# Leave unset to skip the sync step during local-only imports.
# OSM_DATABASE_URL=postgresql://user:password@host/osm?sslmode=require

# ===================================
# AUTHENTICATION & SECURITY
# ===================================
# JWT Configuration
JWT_SECRET=your-jwt-secret-generate-a-secure-random-string

# Password Reset
PASSWORD_RESET_SECRET=your-password-reset-secret-generate-a-secure-random-string

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# ===================================
# EXTERNAL API KEYS
# ===================================
# OpenAI
OPENAI_API_KEY=sk-proj-YOUR-OPENAI-API-KEY
PERPLEXITY_API_KEY=pplx-YOUR-PERPLEXITY-API-KEY

# Weather APIs
WEATHER_API_KEY=your-weather-api-key
OPENWEATHER_KEY=your-openweather-api-key

# PackRat API
PACKRAT_API_KEY=your-packrat-api-key

# ===================================
# EMAIL CONFIGURATION
# ===================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
EMAIL_FROM=no-reply@yourdomain.com

# ===================================
# CLOUDFLARE R2 STORAGE
# ===================================
# R2 Configuration
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_AI_GATEWAY_ID=your-ai-gateway-id
AI_PROVIDER=openai

# R2 Bucket Names
PACKRAT_BUCKET_R2_BUCKET_NAME=your-main-bucket
PACKRAT_ITEMS_BUCKET_R2_BUCKET_NAME=your-items-bucket
PACKRAT_GUIDES_BUCKET_R2_BUCKET_NAME=your-guides-bucket

# R2 Public URL
R2_PUBLIC_URL=https://YOUR-R2-PUBLIC-URL.r2.dev

# ===================================
# CONTAINER CONFIGURATION
# ===================================
# Container Port 
CONTAINER_PORT=8080

# ===================================
# PACKRAT GUIDES CONFIGURATION
# ===================================
PACKRAT_GUIDES_RAG_NAME=packrat-guides-rag
PACKRAT_GUIDES_BASE_URL=https://guides.yourdomain.com/

# ===================================
# PUBLIC / CLIENT CONFIGURATION
# ===================================
# Vars prefixed PUBLIC_ are fanned out by .github/scripts/env.ts (runs on
# postinstall) to each client app using that framework's convention:
#   PUBLIC_FOO  →  EXPO_PUBLIC_FOO  in apps/expo/.env.local
#   PUBLIC_FOO  →  NEXT_PUBLIC_FOO  in apps/admin|landing|guides/.env.local
# Define a client-exposed var once here with PUBLIC_, not per-app.

# API URL
PUBLIC_API_URL=http://localhost:8787

# Google OAuth (mobile only — Expo picks these up as EXPO_PUBLIC_*)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR-GOOGLE-IOS-CLIENT-ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR-GOOGLE-WEB-CLIENT-ID.apps.googleusercontent.com

# Storage (client-exposed)
PUBLIC_R2_PUBLIC_URL=https://YOUR-R2-PUBLIC-URL.r2.dev
R2_PUBLIC_URL=https://YOUR-R2-PUBLIC-URL.r2.dev

# Sentry
EXPO_PUBLIC_SENTRY_DSN=https://YOUR-SENTRY-DSN@o0000000000000000.ingest.us.sentry.io/0000000000000000