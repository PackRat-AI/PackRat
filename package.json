{
	"name": "swarmboard",
	"version": "0.1.0",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"catalog": {
		"elysia": "^1.4.0",
		"@elysiajs/eden": "^1.4.0",
		"@sinclair/typebox": "^0.34.0",
		"@cloudflare/workers-types": "^4.20250214.0",
		"wrangler": "^4.0.0",
		"citty": "^0.1.6",
		"consola": "^3.4.0"
	},
	"scripts": {
		"dev": "bun --filter @swarmboard/api dev",
		"build": "bun --filter '*' build",
		"deploy": "bun --filter @swarmboard/api deploy",
		"test": "bun --filter '*' test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "bun --filter '*' typecheck",
		"version": "bun run scripts/version.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
