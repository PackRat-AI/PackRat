{
  "cli": {
    "version": ">= 7.6.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "channel": "preview"
    },
    "e2e": {
      "ios": {
        "simulator": true,
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "large",
        "gradleCommand": ":app:bundleRelease -x lintVitalAnalyzeRelease",
        "env": {
          "GRADLE_OPTS": "-Xmx6144m -XX:MaxMetaspaceSize=1536m",
          "JAVA_OPTS": "-Xmx6144m"
        }
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production"
      },
      "ios": {
        "ascAppId": "6499243187"
      }
    }
  }
}
