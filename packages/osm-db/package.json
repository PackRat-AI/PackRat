{
  "name": "@packrat/osm-db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun run ./migrate.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.16.3",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
