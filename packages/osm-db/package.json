{
  "name": "@packrat/osm-db",
  "version": "2.0.26",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun run ./migrate.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "ws": "catalog:"
  },
  "devDependencies": {
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
