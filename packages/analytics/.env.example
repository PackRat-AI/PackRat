# Analytics reads from the monorepo root .env automatically (Bun built-in).
# These are the keys it needs:
#
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# CLOUDFLARE_ACCOUNT_ID=...
# PACKRAT_ITEMS_BUCKET_R2_BUCKET_NAME=...
#
# Or override R2_ENDPOINT_URL directly:
# R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
