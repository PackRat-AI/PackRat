{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Native",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "customConditions": ["react-native"],
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true
  }
}
