{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@packrat/app": ["./src/index.ts"],
      "@packrat/app/*": ["./src/*/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
