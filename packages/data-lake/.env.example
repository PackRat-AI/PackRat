# Analytics reads from the monorepo root .env automatically (Bun built-in).
#
# ── Mode ──────────────────────────────────────────────────────────────
# ANALYTICS_MODE=local          # "local" (default) or "catalog"
#
# ── S3/R2 credentials (required for local mode + publish/ingest) ─────
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# CLOUDFLARE_ACCOUNT_ID=...
# PACKRAT_ITEMS_BUCKET_R2_BUCKET_NAME=...
#
# Or override R2_ENDPOINT_URL directly:
# R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
#
# ── Iceberg / R2 Data Catalog (required for catalog mode + publish) ──
# R2_CATALOG_TOKEN=...          # Bearer token from Cloudflare dashboard
# R2_CATALOG_URI=...            # e.g. https://<account>.r2.cloudflarestorage.com
# R2_WAREHOUSE_NAME=...         # Warehouse name in R2 Data Catalog
