# TikTok Service environment variables

# Service configuration
PORT=8080
NODE_ENV=production

# R2 Storage configuration (required for image rehosting)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Optional: If you need to configure the TikTok API library
# TIKTOK_API_TIMEOUT=30000

# Optional: Logging level
# LOG_LEVEL=info