# TikTok Service environment variables
# Used by the container for image rehosting to R2

# R2 Storage configuration (required for image rehosting)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Note: PORT and NODE_ENV are configured in the TikTokContainer class
# and passed to the container as environment variables