{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "swarmboard-api",
	"main": "src/index.ts",
	"compatibility_date": "2025-06-01",
	"r2_buckets": [
		{
			"binding": "SWARMBOARD_BUCKET",
			"bucket_name": "swarmboard-data"
		}
	],
	"vars": {
		"SWARMBOARD_ADMIN_USER": "${SWARMBOARD_ADMIN_USER}",
		"SWARMBOARD_ADMIN_PASS": "${SWARMBOARD_ADMIN_PASS}"
	}
}
