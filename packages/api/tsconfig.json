{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "types": ["@cloudflare/workers-types", "@types/bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@packrat/api/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "migrate.ts",
    "vitest.config.ts",
    "vitest.unit.config.ts"
  ]
}
