{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@packrat/api": ["src/index.ts"],
      "@packrat/api/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "container_src",
    "test",
    "coverage",
    "src/routes/admin/analytics",
    "src/services/userService.ts"
  ]
}
