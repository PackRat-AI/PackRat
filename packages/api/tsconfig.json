{
  "extends": "@packrat/typescript-config/base.json",
  "compilerOptions": {
    "types": ["./worker-configuration.d.ts", "bun"],
    "paths": {
      "@packrat/api": ["./src/index.ts"],
      "@packrat/api/*": ["./src/*"]
    }
