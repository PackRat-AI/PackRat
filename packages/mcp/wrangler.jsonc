{
  "$schema": "https://developers.cloudflare.com/schemas/wrangler.json",
  // ───────────────────────────────────────────────────────────────────────────
  // PackRat MCP Worker
  //
  // The top-level config is the dev base. `wrangler dev` and
  // `wrangler dev -e dev` run against it; `wrangler deploy --env prod` ships
  // the production worker bound to mcp.packrat.world.
  //
  // Required secrets (set per environment via `wrangler secret put <NAME> --env <env>`):
  //   PACKRAT_API_URL              — base URL of the PackRat API (e.g. https://packrat.world)
  //   MCP_INITIAL_ACCESS_TOKEN     — pre-shared bearer required to call POST /register (DCR gate)
  //
  // Optional vars:
  //   MCP_FEATURE_FLAGS            — comma-separated flag names enabled at boot
  //
  // KV bindings (already provisioned — see commit history). The `OAUTH_KV`
  // binding name is what the OAuth-provider library expects; the physical
  // namespace titles in Cloudflare are prefixed for findability among
  // PackRat's other namespaces:
  //   MCP_OAUTH_KV       → 0ac2e23bb4f04dc5a39cfd3d7bc900e0  (prod)
  //   MCP_OAUTH_KV_dev   → be554ba7448c4c13a48e85d9a0cdabc8  (dev / preview)
  // To rotate or recreate:
  //   wrangler kv namespace create MCP_OAUTH_KV       # prod-style
  //   wrangler kv namespace create MCP_OAUTH_KV_dev   # dev-style (no --preview;
  //                                                   #   the dev namespace doubles
  //                                                   #   as the wrangler-dev preview)
  //
  // See docs/mcp/runbook.md for the full deploy + secret-rotation procedure.
  // ───────────────────────────────────────────────────────────────────────────
  "name": "packrat-mcp-dev",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "logpush": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "be554ba7448c4c13a48e85d9a0cdabc8",
      "preview_id": "be554ba7448c4c13a48e85d9a0cdabc8"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "PackRatMCP",
        "class_name": "PackRatMCP"
      }
    ]
  },
  // SQLite-backed DO; required for McpAgent state persistence + hibernation.
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["PackRatMCP"]
    }
  ],
  // U14: Workers Rate Limiting binding for authenticated tool calls AND the
  // /login POST gate. Keyed per-call by `${userId}:${toolName}` for tools and
  // `login:${ip || cfRay}` for the login form. 60 successful checks per 60s
  // is a deliberately humane default for interactive Claude-mediated use;
  // bursts beyond it surface to the model as the U8 `rate_limited` error
  // envelope (retryable=true) so the model can back off and retry.
  //
  // Block-key conventions follow `packages/api/wrangler.jsonc:44`:
  //   - top-level key is `rate_limiting` (not `ratelimits`)
  //   - per-binding field is `binding` (not `name`)
  // `namespace_id` is a free-form Cloudflare identifier (per their docs);
  // `"1"` matches the API package's convention.
  //
  // The binding is wired into:
  //   - `PackRatMCP.installToolRegistrationProxy()` — wraps every tool handler
  //   - `checkLoginRateLimit(env, ip)` in `packages/mcp/src/auth.ts`
  // The dev fallback (`env.MCP_TOOLS_RL` undefined) returns success so local
  // `vitest` and `wrangler dev` don't break when no binding is bound.
  "rate_limiting": [
    {
      "binding": "MCP_TOOLS_RL",
      "namespace_id": "1",
      "simple": { "limit": 60, "period": 60 }
    }
  ],
  // U14: Daily KV purge at 04:00 UTC. The `scheduled` handler in
  // `packages/mcp/src/index.ts` calls `oauthProvider.purgeExpiredData(env)`
  // to sweep orphaned + expired OAuth grants and tokens from KV. KV TTLs
  // alone handle most expiry; this is defense-in-depth + cleanup of
  // orphaned grants whose client was deleted. See docs/mcp/runbook.md
  // § "U14 rate limiting + KV purge" for the operator-facing details and
  // the 30s cron worker-time budget caveat.
  "triggers": {
    "crons": ["0 4 * * *"]
  },
  "env": {
    // ───── Production ──────────────────────────────────────────────────────
    // Custom domain: mcp.packratai.com — brand-aligned with the landing site
    // (packratai.com) so Claude.ai users and connector reviewers see a
    // consistent brand surface. Provisioned in the Cloudflare dashboard
    // against the packratai.com zone. `custom_domain: true` expects a bare
    // hostname pattern (no wildcard), per Cloudflare's worker-domain contract;
    // the worker handles all paths under the hostname.
    "prod": {
      "name": "packrat-mcp",
      "routes": [
        {
          "pattern": "mcp.packratai.com",
          "custom_domain": true
        }
      ],
      "kv_namespaces": [
        {
          "binding": "OAUTH_KV",
          "id": "0ac2e23bb4f04dc5a39cfd3d7bc900e0"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "PackRatMCP",
            "class_name": "PackRatMCP"
          }
        ]
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["PackRatMCP"]
        }
      ],
      "rate_limiting": [
        {
          "binding": "MCP_TOOLS_RL",
          "namespace_id": "1",
          "simple": { "limit": 60, "period": 60 }
        }
      ],
      "triggers": {
        "crons": ["0 4 * * *"]
      }
    },
    // ───── Dev ─────────────────────────────────────────────────────────────
    // Kept as an explicit env so `wrangler deploy --env dev` ships a
    // dedicated worker (packrat-mcp-dev) on the *.workers.dev URL for
    // pre-prod smoke testing without colliding with prod.
    "dev": {
      "name": "packrat-mcp-dev",
      "kv_namespaces": [
        {
          "binding": "OAUTH_KV",
          "id": "be554ba7448c4c13a48e85d9a0cdabc8",
          "preview_id": "be554ba7448c4c13a48e85d9a0cdabc8"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "PackRatMCP",
            "class_name": "PackRatMCP"
          }
        ]
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["PackRatMCP"]
        }
      ],
      "rate_limiting": [
        {
          "binding": "MCP_TOOLS_RL",
          "namespace_id": "1",
          "simple": { "limit": 60, "period": 60 }
        }
      ],
      "triggers": {
        "crons": ["0 4 * * *"]
      }
    }
  }
}
