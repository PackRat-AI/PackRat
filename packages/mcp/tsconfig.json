{
  "extends": "@packrat/typescript-config/base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types/2022-10-31"],
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@packrat/api-client": ["../api-client/src/index.ts"],
      "@packrat/api-client/*": ["../api-client/src/*"],
      "@packrat/api/*": ["../api/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
