# Copy this file to .env and fill in the values.
# Bun loads .env automatically when you run `bun run import` or `bun run sync`.

# ── Required ──────────────────────────────────────────────────────────────────

# Connection string for the LOCAL PostGIS instance (the Docker container that
# osm2pgsql writes into). This is your scratch/processing database — it holds
# the full slim tables and is not meant to be exposed publicly.
#
# If you started the container with the compose/docker run commands in the README:
OSM_DATABASE_URL=postgresql://packrat:packrat@localhost:5433/osm

# ── Optional ──────────────────────────────────────────────────────────────────

# Connection string for your MANAGED (production) PostgreSQL database.
# When set, `bun run import` will automatically call `bun run sync` at the end,
# dumping osm_ways + osm_routes from the local DB and restoring them here.
# Leave unset to skip the sync step (useful for testing imports locally).
#
# Examples:
#   Supabase:  postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#   Neon:      postgresql://[user]:[password]@[host].neon.tech/osm?sslmode=require
#   RDS:       postgresql://[user]:[password]@[host].rds.amazonaws.com:5432/osm
# MANAGED_DB_URL=

# Import mode for osm2pgsql:
#   create  — drops and recreates output tables (default, use for full reimports)
#   append  — adds to existing tables without dropping (use for incremental .osc diffs)
# IMPORT_MODE=create
