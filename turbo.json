{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV", "CI", "NEXT_PUBLIC_*", "EXPO_PUBLIC_*", "APP_VARIANT"],
  "globalDependencies": ["tsconfig.json", "biome.json", "bunfig.toml", ".npmrc"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*", "!**/__tests__/**"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "inputs": ["$TURBO_DEFAULT$", "../../tsconfig.json", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "vitest*.config.ts", "package.json", "tsconfig.json"]
    },
    "test:unit:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "vitest*.config.ts", "package.json", "tsconfig.json"],
      "outputs": ["coverage/**"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "vitest*.config.ts", "package.json", "tsconfig.json"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["^build", "build"],
      "cache": false
    }
  }
}
