{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "esModuleInterop": true,
    "lib": ["DOM", "ESNext"],
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "target": "ESNext",
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-native",
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "admin-app/*": ["./apps/admin/*"],
      "guides-app/*": ["./apps/guides/*"],
      "landing-app/*": ["./apps/landing/*"],
      "expo-app/*": ["./apps/expo/*"],
      "app/*": ["./packages/app/*"],
      "@packrat/api/*": ["./packages/api/src/*"],
      "@packrat/guards": ["./packages/guards/src"],
      "@packrat/guards/*": ["./packages/guards/src/*"],
      "@packrat/ui/*": ["./packages/ui/*"],
      "@packrat/analytics/*": ["./packages/analytics/src/*"],
      "@packrat/web-ui": ["./packages/web-ui/src"],
      "@packrat/web-ui/*": ["./packages/web-ui/src/*"],
      "nativewindui/*": ["./apps/expo/components/ui/*"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/.next",
    "**/.expo",
    "**/coverage",
    "packages/api/container_src"
  ]
}
